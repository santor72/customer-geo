<?xml version="1.0" encoding="UTF-8" ?>
<project name="CustomerGeomap" database="MariaDb" id="0096fd98-1764-41c3-943a-2ff531456344" >
	<schema name="schema_agg_month" >
		<table name="agg_customer_month" >
			<comment><![CDATA[Витрина данных о клиентах с историей по месяцам
месяц recv_mon YYYY-MM-DD - последний день месяца к которому относятся данные]]></comment>
			<column name="recv_mon" type="VARCHAR" >
				<comment><![CDATA[Месяц отчета]]></comment>
			</column>
			<column name="account_id" type="INT" >
				<comment><![CDATA[идентификатор клиента]]></comment>
			</column>
			<column name="settlement_id" type="INT" >
				<comment><![CDATA[идентификатор поселка]]></comment>
			</column>
			<column name="lat" type="NUMERIC" >
				<comment><![CDATA[Широта]]></comment>
			</column>
			<column name="lng" type="NUMERIC" >
				<comment><![CDATA[Долгота]]></comment>
			</column>
			<column name="is_active" type="BOOLEAN" >
				<comment><![CDATA[Признак активного клиента]]></comment>
			</column>
			<column name="is_sysblock" type="BOOLEAN" >
				<comment><![CDATA[Признак заблокированного клиента]]></comment>
			</column>
			<column name="charges_sum_m" type="DOUBLE" >
				<comment><![CDATA[Сумма списаний за период]]></comment>
			</column>
			<column name="payments_sum_m" type="DOUBLE" >
				<comment><![CDATA[Сумма платежей клиента за период]]></comment>
			</column>
			<index name="idx_agg_customer_month" unique="NORMAL" >
				<column name="recv_mon" />
				<column name="account_id" />
			</index>
		</table>
