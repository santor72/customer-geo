			<column name="charges_cnt_m" type="INT" >
				<comment><![CDATA[Количество  списаний за период]]></comment>
			</column>
			<column name="payments_cnt_m" type="INT" >
				<comment><![CDATA[Количество  платежей за период]]></comment>
