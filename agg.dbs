ALTER TABLE agg_settlement_month MODIFY settlement_id INT     COMMENT 'идентификатор поселка';

ALTER TABLE agg_settlement_month MODIFY lat NUMERIC     COMMENT 'Широта';

ALTER TABLE agg_settlement_month MODIFY lng NUMERIC     COMMENT 'Долгота';

ALTER TABLE agg_settlement_month MODIFY active_cnt INT     COMMENT 'Количство  активных клиентов';

