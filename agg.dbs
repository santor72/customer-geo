				<string><![CDATA[CREATE SCHEMA schema_agg_month;

CREATE  TABLE agg_customer_month ( 
	recv_mon             VARCHAR       ,
	account_id           INT       ,
	settlement_id        INT       ,
	lat                  NUMERIC       ,
	lng                  NUMERIC       ,
	is_active            BOOLEAN       ,
	is_sysblock          BOOLEAN       ,
	charges_sum_m        DOUBLE       ,
	payments_sum_m       DOUBLE       
 );

CREATE INDEX idx_agg_customer_month ON agg_customer_month ( recv_mon, account_id );

ALTER TABLE agg_customer_month COMMENT 'Витрина данных о клиентах с историей по месяцам
месяц recv_mon YYYY-MM-DD - последний день месяца к которому относятся данные';

ALTER TABLE agg_customer_month MODIFY recv_mon VARCHAR     COMMENT 'Месяц отчета';

ALTER TABLE agg_customer_month MODIFY account_id INT     COMMENT 'идентификатор клиента';

ALTER TABLE agg_customer_month MODIFY settlement_id INT     COMMENT 'идентификатор поселка';

ALTER TABLE agg_customer_month MODIFY lat NUMERIC     COMMENT 'Широта';

ALTER TABLE agg_customer_month MODIFY lng NUMERIC     COMMENT 'Долгота';

ALTER TABLE agg_customer_month MODIFY is_active BOOLEAN     COMMENT 'Признак активного клиента';

ALTER TABLE agg_customer_month MODIFY is_sysblock BOOLEAN     COMMENT 'Признак заблокированного клиента';

ALTER TABLE agg_customer_month MODIFY charges_sum_m DOUBLE     COMMENT 'Сумма списаний за период';

ALTER TABLE agg_customer_month MODIFY payments_sum_m DOUBLE     COMMENT 'Сумма платежей клиента за период';

CREATE  TABLE agg_h3_month ( 
	recv_mon             VARCHAR       ,
	h3_res               INT       ,
	h3_index             BIGINT       ,
	active_cnt           INT       ,
	sysblock_cnt         BOOLEAN       ,
	charges_sum_m        DOUBLE       ,
	payments_sum_m       DOUBLE       ,
	charges_cnt_m        INT       ,
	payments_cnt_m       INT       
 );

CREATE INDEX idx_agg_h3_month ON agg_h3_month ( recv_mon, h3_res, h3_index );

ALTER TABLE agg_h3_month COMMENT 'Витрина данных о гексагонах с историей по месяцам
месяц recv_mon YYYY-MM-DD - последний день месяца к которому относятся данные';

ALTER TABLE agg_h3_month MODIFY recv_mon VARCHAR     COMMENT 'Месяц отчета';

ALTER TABLE agg_h3_month MODIFY h3_res INT     COMMENT 'h3 resolution';

ALTER TABLE agg_h3_month MODIFY h3_index BIGINT     COMMENT 'H3 index';

ALTER TABLE agg_h3_month MODIFY active_cnt INT     COMMENT 'Количство  активных клиентов';

ALTER TABLE agg_h3_month MODIFY sysblock_cnt BOOLEAN     COMMENT 'Количство  заблокированных клиентов';

ALTER TABLE agg_h3_month MODIFY charges_sum_m DOUBLE     COMMENT 'Сумма списаний за период';

ALTER TABLE agg_h3_month MODIFY payments_sum_m DOUBLE     COMMENT 'Сумма платежей клиента за период';

ALTER TABLE agg_h3_month MODIFY charges_cnt_m INT     COMMENT 'Количество  списаний за период';

ALTER TABLE agg_h3_month MODIFY payments_cnt_m INT     COMMENT 'Количество  платежей за период';

CREATE  TABLE agg_settlement_month ( 
	recv_mon             VARCHAR       ,
	settlement_id        INT       ,
	lat                  NUMERIC       ,
	lng                  NUMERIC       ,
	active_cnt           INT       ,
	sysblock_cnt         BOOLEAN       ,
	charges_sum_m        DOUBLE       ,
	payments_sum_m       DOUBLE       ,
	charges_cnt_m        INT       ,
	payments_cnt_m       INT       
 );

CREATE INDEX idx_agg_settlement_month ON agg_settlement_month ( recv_mon, settlement_id );

ALTER TABLE agg_settlement_month COMMENT 'Витрина данных о поселках  историей по месяцам
месяц recv_mon YYYY-MM-DD - последний день месяца к которому относятся данные';

